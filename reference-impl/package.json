{
  "name": "agrp-wmlet",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "bun scripts/dev.ts fg",
    "build": "bun run css:build && bun run js:build",
    "css:build": "bunx @tailwindcss/cli -i ui/tailwind.css -o public/styles/main.css --minify",
    "css:watch": "bunx @tailwindcss/cli -i ui/tailwind.css -o public/styles/main.css --watch=always",
    "js:build": "bun build ui/datastar-entry.ts --target=browser --minify --outfile=public/js/datastar.js",
    "js:vendor": "mkdir -p public/js && curl -sL https://unpkg.com/htmx.org@2.0.4/dist/htmx.min.js -o public/js/htmx.min.js && curl -sL https://cdn.jsdelivr.net/npm/marked@15/marked.min.js -o public/js/marked.min.js",
    "setup": "bun install && bun run js:vendor && bun run build",
    "wmlet": "bun run wmlet.ts",
    "manager": "bun run wsmanager.ts",
    "dev:wmlet": "bun --watch run wmlet.ts",
    "dev:manager": "bun --watch run wsmanager.ts",
    "ws": "bun run cli.ts",
    "test": "bun run test.ts"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.15.0",
    "@starfederation/datastar": "1.0.0-beta.11",
    "@zed-industries/claude-agent-acp": "^0.21.0",
    "beautiful-mermaid": "^1.1.3",
    "shiki": "^4.0.2"
  },
  "private": true,
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "@tailwindcss/typography": "^0.5.19",
    "@types/bun": "latest",
    "tailwindcss": "^4.2.2"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
